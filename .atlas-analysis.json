  "keyFeatures": [
    "Real-time uptime monitoring with multi-region checks",
    "ClickHouse-powered time-series database for high-performance metrics storage",
    "Public status pages with custom domain support",
    "Redis streams for distributed check processing",
    "tRPC API for type-safe client-server communication",
    "Docker-based deployment for both development and production",
    "OAuth authentication with GitHub integration",
    "Email notifications via Resend"
  ],
